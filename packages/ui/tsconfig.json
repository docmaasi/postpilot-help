{
  "extends": "../config/tsconfig.react.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@postpilot/lib": ["../lib/src/index.js"],
      "@postpilot/lib/*": ["../lib/src/*"]
    }
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.*"]
}
